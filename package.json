{
  "name": "rojo",
  "productName": "RO^JO File Downloader",
  "version": "1.0.0",
  "description": "Fast, minimal BitTorrent client",
  "main": "src/main.js",
  "author": "Rojo",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.rojo.torrent",
    "productName": "Rojo",
    "directories": {
      "output": "dist"
    },
    "npmRebuild": false,
    "files": [
      "src/**/*",
      "assets/**/*",
      "vpn/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      "assets/icon.png",
      "assets/logo.png",
      "assets/tray-icon.png"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "mergeASARs": false,
      "extendInfo": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "BitTorrent Magnet Link",
            "CFBundleURLSchemes": [
              "magnet"
            ]
          }
        ],
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeExtensions": [
              "torrent"
            ],
            "CFBundleTypeIconFile": "icon.icns",
            "CFBundleTypeName": "Torrent File",
            "CFBundleTypeRole": "Editor",
            "LSHandlerRank": "Default",
            "LSItemContentTypes": [
              "org.bittorrent.torrent"
            ]
          }
        ],
        "UTImportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "org.bittorrent.torrent",
            "UTTypeDescription": "Torrent File",
            "UTTypeIconFile": "icon.icns",
            "UTTypeConformsTo": [
              "public.data"
            ],
            "UTTypeTagSpecification": {
              "public.filename-extension": [
                "torrent"
              ]
            }
          }
        ]
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "protocols": [
      {
        "name": "BitTorrent Magnet Link",
        "schemes": [
          "magnet"
        ]
      }
    ]
  },
  "dependencies": {
    "basic-ftp": "^6.0.1",
    "cheerio": "^1.2.0",
    "ssh2": "^1.17.0",
    "webtorrent": "^2.4.29"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
